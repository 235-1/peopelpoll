<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xbx.peoplepoll.mapper.UserPostCountMapper">


    <select id="selectAll" resultType="com.xbx.peoplepoll.pojo.UserPost">
        select
        user_authentication,
        count,
        create_time
        from user_post_count
    </select>
</mapper>