<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xbx.peoplepoll.mapper.RegionHotMapper">
    <select id="selectAll" resultType="com.xbx.peoplepoll.pojo.RegionHot">
        select
        region,
        count,
        hot,
        create_time
        from regionHot
        order by hot desc
    </select>
</mapper>