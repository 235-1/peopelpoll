<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xbx.peoplepoll.mapper.TimePeriodCountMapper">


    <select id="selectAll" resultType="com.xbx.peoplepoll.pojo.TimePost">
