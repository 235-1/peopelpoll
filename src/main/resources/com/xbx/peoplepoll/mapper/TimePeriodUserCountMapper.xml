<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xbx.peoplepoll.mapper.TimePeriodUserCountMapper">
    <select id="selectAll" resultType="com.xbx.peoplepoll.pojo.TimePeriodUser">
        select
        time_period,
        user_authentication,
        count,
        create_time
        from
        time_period_user_count
    </select>
</mapper>