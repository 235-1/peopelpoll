<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xbx.back.mapper.ProjectMemMapper">

    <select id="getAll" resultType="com.xbx.back.pojo.ProjectMem">
        select
               id,
               title,
               description,
               path,
               domain,
               icon,
               sort,
               is_show,
               remark,
               img,
               create_time,
               update_time
        from project_mem
    </select>
</mapper>